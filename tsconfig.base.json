{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": [],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@praxis/core-engine": ["packages/core-engine/src/index.ts"],
      "@praxis/module-languages": ["packages/module-languages/src/index.ts"],
      "@praxis/module-ml": ["packages/module-ml/src/index.ts"],
      "@praxis/ui-kit": ["packages/ui-kit/src/index.ts"]
    }
  }
}
