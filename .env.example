# Praxis — пример переменных окружения.
# Скопировать в .env (в git не коммитится). Секреты — ТОЛЬКО здесь, никогда в клиенте.

# --- Backend (services/api) ---
# PostgreSQL
DATABASE_URL=postgresql+psycopg://praxis:praxis@localhost:5432/praxis

# Claude API (используется только backend'ом; НЕ попадает в мобильный клиент)
CLAUDE_API_KEY=

# Окружение
APP_ENV=development

# --- Mobile client (apps/mobile) ---
# Базовый URL backend'а (EXPO_PUBLIC_* видны клиенту — сюда НЕ класть секреты)
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000
